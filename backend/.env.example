# --- Core ---
PORT=5001
JWT_SECRET=replace_with_a_long_random_secret
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/typeify?retryWrites=true&w=majority

# --- Email (OTP verification) — Brevo transactional HTTP API ---
# Brevo dashboard → SMTP & API → API Keys (starts with "xkeysib-").
BREVO_API_KEY=your_brevo_api_key
# A verified sender address (Brevo → Senders & IPs).
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=Typeify

# --- AI passage generation + coaching (Groq, free) ---
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
# Optional: GROQ_MODEL (defaults to llama-3.1-8b-instant)
