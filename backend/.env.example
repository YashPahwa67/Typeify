# --- Core ---
PORT=5001
JWT_SECRET=replace_with_a_long_random_secret
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/typeify?retryWrites=true&w=majority

# --- Email (OTP verification) — Gmail SMTP ---
# EMAIL_PASS must be a Gmail App Password (2-Step Verification required):
# https://myaccount.google.com/apppasswords
EMAIL_USER=you@gmail.com
EMAIL_PASS=your_gmail_app_password

# --- AI passage generation + coaching (Groq, free) ---
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
# Optional: GROQ_MODEL (defaults to llama-3.1-8b-instant)
